dd if=/dev/zero of=part.bin bs=512 count=65536
mkfs.fat -F 16 -S 512 -s 4 -r 512 -n "DASHCRYSTALOS" part.bin
# Monter et ajouter un fichier (Linux)
mkdir -p /tmp/mnt
sudo mount -o loop part.bin /tmp/mnt
echo "Hello DashCrystalOS!" | sudo tee /tmp/mnt/HELLO.TXT
sudo umount /tmp/mnt


qemu-system-i386 -m 512M -machine pc -hda os.bin -serial stdio